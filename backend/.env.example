# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_image_db

# Security (REQUIRED - generate a secure random key)
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Image Generator Provider (gemini)
# Default: gemini (recommended)
IMAGE_GENERATOR_PROVIDER=gemini

# Gemini API (Primary Provider)
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# Gemini model (gemini-2.0-flash-exp, gemini-2.5-flash-preview-05-20, gemini-2.5-flash-image, etc.)
GEMINI_MODEL=gemini-2.5-flash-image

# Image storage
IMAGE_STORAGE_PATH=./generated_images

# App
APP_NAME=AI Image Generator
DEBUG=true

# Logging
LOG_LEVEL=INFO
# LOG_FILE=./logs/app.log

# Default Admin User (optional - for first-time setup)
# CREATE_DEFAULT_ADMIN=true
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=admin123
# DEFAULT_ADMIN_EMAIL=admin@example.com
