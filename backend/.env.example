# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_image_db

# Security (REQUIRED - generate a secure random key)
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Image Generator Provider (gemini, banana, replicate)
# Default: gemini (recommended)
IMAGE_GENERATOR_PROVIDER=gemini

# Gemini API (Primary Provider)
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# Gemini model (gemini-2.0-flash-exp, gemini-2.5-flash-preview-05-20, etc.)
GEMINI_MODEL=gemini-2.0-flash-exp

# Banana.dev API (Optional - for Stable Diffusion)
# Get API key from: https://banana.dev/
BANANA_API_KEY=your-banana-api-key
BANANA_MODEL_KEY=stable-diffusion-v1-5

# Replicate API (Optional)
# Get API key from: https://replicate.com/account
REPLICATE_API_KEY=your-replicate-api-key

# Image storage
IMAGE_STORAGE_PATH=./generated_images

# App
APP_NAME=AI Image Generator
DEBUG=true

# Logging
LOG_LEVEL=INFO
# LOG_FILE=./logs/app.log
