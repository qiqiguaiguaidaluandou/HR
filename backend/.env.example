# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_image_db

# Security (REQUIRED - generate a secure random key)
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Banana.dev API
BANANA_API_KEY=your-banana-api-key
BANANA_MODEL_KEY=stable-diffusion-v1-5

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Image storage
IMAGE_STORAGE_PATH=./generated_images

# App
APP_NAME=AI Image Generator
DEBUG=true
